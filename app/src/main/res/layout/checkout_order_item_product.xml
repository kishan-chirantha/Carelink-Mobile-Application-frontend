<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/checkout_item_imgContainer"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@color/md_theme_surfaceContainerLow"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/checkout_item_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:scaleType="centerInside"/>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/checkout_item_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Classic Haven"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface" />

        <TextView
            android:id="@+id/checkout_item_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chair"
            android:textSize="12sp"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/checkout_item_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LKR 2499"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:background="@color/md_theme_outlineVariant"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/checkout_item_qty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qty. 1"
                android:textSize="13sp"
                android:textColor="@color/md_theme_onSurfaceVariant" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>