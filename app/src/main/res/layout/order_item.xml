<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/md_theme_outlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="@color/md_theme_inverseOnSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <TextView
                    android:id="@+id/iv_order_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                android:text="#"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_onPrimaryContainer"/>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/order_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Health &amp; Medicine"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/order_item_customer_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="For Rishith Himansa - 789 920 062"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="10.5sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/order_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="03 March 2026"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="11.5sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/order_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="07:32 PM"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:alpha="0.5" android:background="@color/md_theme_outlineVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/status_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/md_theme_primaryContainer"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp">
                    <View
                        android:id="@+id/status_card_dot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="5dp"
                        android:background="@drawable/circle_bg"
                        android:backgroundTint="@color/md_theme_primary" />
                    <TextView
                        android:id="@+id/order_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completed"
                        android:textColor="@color/md_theme_onPrimaryContainer"
                        android:textSize="11.5sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/order_item_call_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/md_theme_secondaryContainer"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:id="@+id/btn_thumbs_up"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_margin="5dp"
                    android:src="@drawable/call"
                    app:tint="@color/md_theme_primary" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:alpha="0.5" android:background="@color/md_theme_outlineVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="18dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginTop="2dp"
                    app:cardBackgroundColor="@color/md_theme_primary"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/md_theme_surfaceContainerLowest"
                    app:strokeWidth="2dp" />

                <View android:layout_width="2dp" android:layout_height="4dp" android:layout_marginTop="3dp" android:layout_gravity="center_horizontal" android:background="@color/md_theme_outlineVariant" />
                <View android:layout_width="2dp" android:layout_height="4dp" android:layout_marginTop="3dp" android:layout_gravity="center_horizontal" android:background="@color/md_theme_outlineVariant" />
                <View android:layout_width="2dp" android:layout_height="4dp" android:layout_marginTop="3dp" android:layout_gravity="center_horizontal" android:background="@color/md_theme_outlineVariant" />
                <View android:layout_width="2dp" android:layout_height="4dp" android:layout_marginTop="3dp" android:layout_gravity="center_horizontal" android:background="@color/md_theme_outlineVariant" />
                <View android:layout_width="2dp" android:layout_height="4dp" android:layout_marginTop="3dp" android:layout_gravity="center_horizontal" android:background="@color/md_theme_outlineVariant" />
                <View android:layout_width="2dp" android:layout_height="4dp" android:layout_marginTop="3dp" android:layout_gravity="center_horizontal" android:background="@color/md_theme_outlineVariant" />
                <View android:layout_width="2dp" android:layout_height="4dp" android:layout_marginTop="3dp" android:layout_gravity="center_horizontal" android:background="@color/md_theme_outlineVariant" />
                <View android:layout_width="2dp" android:layout_height="4dp" android:layout_marginTop="3dp" android:layout_gravity="center_horizontal" android:background="@color/md_theme_outlineVariant" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginTop="3dp"
                    app:cardBackgroundColor="@color/md_theme_tertiary"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/md_theme_surfaceContainerLowest"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="PICKUP"
                    android:textAllCaps="true"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/order_pharmacy_name_and_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.25"
                    android:text="Keells (Maharagama 1) – 226, High Level Rd, Maharagama 10280"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View android:layout_width="match_parent" android:layout_height="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="DELIVERY"
                    android:textAllCaps="true"
                    android:textColor="@color/md_theme_tertiary"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/order_customer_delivery_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.25"
                    android:text="62, Navinna Hostel Road, Maharagama, Colombo"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:alpha="0.5" android:background="@color/md_theme_outlineVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/order_btn_details"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.01"
                android:text="View Details"
                android:textAllCaps="false"
                android:textColor="@color/md_theme_primary"
                android:textSize="12.5sp"
                android:textStyle="bold"
                app:iconSize="14dp"
                app:iconTint="@color/md_theme_primary"
                app:rippleColor="@color/md_theme_primaryContainer" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/md_theme_secondaryContainer"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:id="@+id/iv_payment_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_margin="5dp"
                    android:src="@drawable/credit_card"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/order_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LKR 1,209.54"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>