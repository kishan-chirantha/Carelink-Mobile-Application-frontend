<?xml version="1.0" encoding="utf-8"?><androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    xmlns:tools="http://schemas.android.com/tools">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_background"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/orders_backButton"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/back1"
                app:iconSize="20dp"
                app:iconTint="@color/md_theme_onBackground" />

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/order_details_header_txt"
                android:textColor="@color/md_theme_onBackground"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/downloadInvoiceButton"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/info"
                app:iconSize="20dp"
                app:iconTint="@color/md_theme_onBackground" />
        </androidx.appcompat.widget.Toolbar>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.35"
            android:background="@color/md_theme_outlineVariant" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_delivery_banner"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:layout_weight="1"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="202dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.06"
                        android:text="ORDER ID"
                        android:textAllCaps="true"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="10.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/order_details_order_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:letterSpacing="-0.01"
                        android:text="1315678307"
                        android:textColor="@color/md_theme_onBackground"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/user_outline"
                            app:tint="@color/md_theme_onSurfaceVariant" />

                        <TextView
                            android:id="@+id/order_details_customer_name_and_mobile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kishan - 0789920062"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="108dp"
                    android:layout_height="78dp"
                    android:src="@drawable/delivery"
                    android:alpha="0.25"
                    app:tint="@color/md_theme_onBackground" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="12dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="10dp"
                            app:cardBackgroundColor="@color/md_theme_inverseOnSurface"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <TextView
                                android:id="@+id/iv_order_icon"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="#"
                                android:textColor="@color/md_theme_onPrimaryContainer"
                                android:textSize="26sp"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_order_type"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Health &amp; Medicine"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/order_details_order_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="03 March 2026"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/order_details_order_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="1dp"
                                android:text="07:32 PM"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="11.5sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.5"
                        android:background="@color/md_theme_outlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/order_details_status_card"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/md_theme_primaryContainer"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="8dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="4dp">

                                <View
                                    android:id="@+id/order_details_st_dot"
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/circle_bg"
                                    android:backgroundTint="@color/md_theme_primary" />

                                <TextView
                                    android:id="@+id/order_details_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Completed"
                                    android:textColor="@color/md_theme_onPrimaryContainer"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="@color/md_theme_secondaryContainer"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <ImageView
                                android:id="@+id/btn_thumb_down"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_margin="5dp"
                                android:src="@drawable/thumb_down"
                                app:tint="@color/md_theme_onSurfaceVariant" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/md_theme_primaryContainer"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <ImageView
                                android:id="@+id/btn_thumbs_up"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_margin="5dp"
                                android:src="@drawable/thumb_up"
                                app:tint="@color/md_theme_primary" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginTop="2dp"
                            app:cardBackgroundColor="@color/md_theme_primary"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/md_theme_surfaceContainerLowest"
                            app:strokeWidth="2dp" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="4dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="3dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginTop="3dp"
                            app:cardBackgroundColor="@color/md_theme_tertiary"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/md_theme_surfaceContainerLowest"
                            app:strokeWidth="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="PICKUP"
                            android:textAllCaps="true"
                            android:textColor="@color/md_theme_primary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/order_details_pharmacy_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:lineSpacingMultiplier="1.3"
                            android:text="Keells (Maharagama 1) – 226, High Level Rd, Maharagama 10280"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/order_details_pickup_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="2026-03-03 - 19:32 PM"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="DELIVERY"
                            android:textAllCaps="true"
                            android:textColor="@color/md_theme_tertiary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/order_details_delivery_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:lineSpacingMultiplier="1.3"
                            android:text="62, Navinna Hostel Road, Maharagama, Colombo"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/order_details_delivered_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="2026-03-03 - 19:39 PM"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Order Details"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/order_details_pharmacy_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Keells (Maharagama 1)"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="12.5sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.5"
                        android:background="@color/md_theme_outlineVariant" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/order_details_product_recycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:visibility="visible" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/order_details_prescription_recycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:nestedScrollingEnabled="false"
                        android:visibility="visible" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:alpha="0.5"
                        android:background="@color/md_theme_outlineVariant" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@color/md_theme_surfaceContainerLow"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Sub Total"
                                    android:textColor="@color/md_theme_onSurfaceVariant"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/order_details__subtotal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+ LKR 0.00"
                                    android:textColor="@color/md_theme_onSurface"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View
                                android:id="@+id/prescription_fee_divider"
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:alpha="0.4"
                                android:background="@color/md_theme_outlineVariant" />

                            <LinearLayout
                                android:id="@+id/prescription_fee_layout"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Prescription Fee"
                                    android:textColor="@color/md_theme_onSurfaceVariant"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/order_details_prescription_fee"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+ LKR 0.00"
                                    android:textColor="@color/md_theme_onSurface"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:alpha="0.4"
                                android:background="@color/md_theme_outlineVariant" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Delivery Fee"
                                    android:textColor="@color/md_theme_onSurfaceVariant"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/order_details_delivery_fee"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+ LKR 0.00"
                                    android:textColor="@color/md_theme_onSurface"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="@color/md_theme_primaryContainer"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Total Amount"
                                android:textColor="@color/md_theme_onPrimaryContainer"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/order_details_total_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LKR 0.00"
                                android:textColor="@color/md_theme_onPrimaryContainer"
                                android:textSize="17sp"
