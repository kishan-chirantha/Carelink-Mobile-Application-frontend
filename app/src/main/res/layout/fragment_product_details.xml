<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/topBackground"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:background="@drawable/bg_top_area"
                app:layout_constraintTop_toTopOf="parent" />


            <ImageView
                android:id="@+id/product_details_backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_back_button"
                android:padding="10dp"
                android:src="@drawable/back1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#000" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/product_details_product_img"
                android:layout_width="0dp"
                android:layout_height="260dp"
                android:layout_marginHorizontal="32dp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/product_details_backBtn"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                android:id="@+id/dots_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:dotsColor="@color/md_theme_secondaryContainer"
                app:dotsSize="10dp"
                app:layout_constraintBottom_toBottomOf="@id/topBackground"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:selectedDotColor="@color/md_theme_primary" />

            <TextView
                android:id="@+id/product_details_product_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:text="Vitamin C 1000mg"
                android:textColor="#111111"
                android:textSize="21sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/topBackground"/>

            <TextView
                android:id="@+id/product_details_product_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="6dp"
                android:text="Rs. 850.00"
                android:textColor="@color/md_theme_primary"
                android:textSize="19sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/product_details_product_name"/>

            <TextView
                android:id="@+id/product_details_category_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:text="Tablets"
                android:textColor="#7A7A7A"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/product_details_product_price"/>

            <LinearLayout
                android:id="@+id/quantityContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/product_details_category_name">

                <TextView
                    android:id="@+id/quantity_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quantity:"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginEnd="12dp"/>

                <ImageView
                    android:id="@+id/product_details_btnMinus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_outlined"
                    android:padding="7dp"
                    android:src="@drawable/minus"
                    app:tint="@color/md_theme_primary"/>

                <TextView
                    android:id="@+id/product_details_product_quantity"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/product_details_btnPlus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_outlined"
                    android:padding="7dp"
                    android:src="@drawable/plus"
                    app:tint="@color/md_theme_primary"/>

            </LinearLayout>

            <TextView
                android:id="@+id/product_details_product_description"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:lineSpacingExtra="4dp"
                android:text="Vitamin C 1000mg is a high-strength dietary supplement designed to support the immune system and promote overall health. It helps protect cells from oxidative stress while boosting natural defenses. Ideal for daily wellness and maintaining a healthy lifestyle."
                android:textColor="#6B7280"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/quantityContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/product_details_btnAddToCart"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Add to Cart"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/md_theme_primary"
            app:cornerRadius="18dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>