<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="match_parent"
        android:layout_height="280dp" />

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-40dp"
        android:alpha="0.20" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="44dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/profile_btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_quantity_selector"
            android:src="@drawable/back1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="User Profile"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnEditTop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_quantity_selector"
            android:src="@drawable/info" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="155dp"
                android:layout_marginBottom="10dp">

                <RelativeLayout
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="52dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle">

                    <ImageView
                        android:id="@+id/profile_customer_proImg"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:padding="12dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/user_outline_2"
                        android:background="@drawable/bg_quantity_selector"/>

                    <LinearLayout
                        android:id="@+id/profile_customer_upload_profileImg"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/bg_quantity_selector"
                        android:gravity="center"
                        android:elevation="6dp">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/camera" />
                    </LinearLayout>
                </RelativeLayout>

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-20dp"
                android:paddingTop="28dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERSONAL INFORMATION"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_profile_input_field"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/user_filled"
                            android:layout_marginEnd="10dp"
                            app:tint="@color/md_theme_primary" />

                        <EditText
                            android:id="@+id/profile_customer_fullname"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="15sp"
                            android:inputType="textPersonName"
                            android:singleLine="true"
                            android:hint="Enter full name"
                            android:textColorHint="@color/md_theme_outline" />
                    </LinearLayout>
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="E-Mail"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_profile_input_field"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/at"
                            android:layout_marginEnd="10dp"
                            app:tint="@color/md_theme_tertiary" />

                        <EditText
                            android:id="@+id/profile_customer_email"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="15sp"
                            android:inputType="textEmailAddress"
                            android:singleLine="true"
                            android:hint="Enter email"
                            android:textColorHint="@color/md_theme_outline"
                            android:focusable="false"
                            android:clickable="false"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ unchanged"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            android:backgroundTint="@color/md_theme_primaryContainer"
                            android:background="@drawable/bg_category_filled"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_profile_input_field"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/call"
                            android:layout_marginEnd="10dp"
                            app:tint="@color/md_theme_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+94"
                            android:textColor="@color/md_theme_primary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginEnd="10dp" />

                        <EditText
                            android:id="@+id/profile_customer_mobile"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="15sp"
                            android:inputType="phone"
                            android:singleLine="true"
                            android:hint="Enter mobile number"
                            android:textColorHint="@color/md_theme_outline" />
                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/md_theme_background"
        android:elevation="10dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profile_btn_save"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.6"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/md_theme_primary"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:rippleColor="#40FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_pay_now_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.03"
                        android:text="Save Changes"
                        android:textColor="@android:color/white"
                        android:textSize="15sp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>