<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surfaceContainerLow">

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/md_theme_surfaceContainerLow"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:text="Settings"
            android:textColor="@color/md_theme_onBackground"
            android:textSize="22sp" />

        <LinearLayout
            android:id="@+id/btn_more"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/info" />

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="84dp"
        android:layout_marginBottom="70dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/row_profile_info"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@color/md_theme_background"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:id="@+id/setting_avatar"
                        android:layout_width="46dp"
                        android:padding="7dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="14dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_filled"
                        android:background="@drawable/bg_quantity_selector"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/setting_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Kasun Perera"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/setting_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="kasun@gmail.com"
                            android:textColor="@color/md_theme_outline"
                            android:textSize="12sp" />
                    </LinearLayout>


                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:paddingStart="2dp">

                    <LinearLayout
                        android:id="@+id/setting_profile_container"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_quantity_selector"
                            android:gravity="center"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/user_outline"
                                app:tint="@color/md_theme_onSurfaceVariant"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="User Profile"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Manage your profile details"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/arrow"
                            app:tint="@color/md_theme_outlineVariant"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/md_theme_outlineVariant" />

                    <LinearLayout
                        android:id="@+id/setting_language_container"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_quantity_selector"
                            android:gravity="center"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/world"
                                app:tint="@color/md_theme_secondaryFixedDim_mediumContrast"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Language"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:text="Choose your preferred language"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/arrow"
                            app:tint="@color/md_theme_outlineVariant"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_theme_outlineVariant"
                        android:layout_marginStart="56dp"/>

                    <LinearLayout
                        android:id="@+id/setting_privacy_container"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_quantity_selector"
                            android:gravity="center"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/shield_lock"
                                app:tint="@color/md_theme_secondaryFixedDim_mediumContrast"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Passcode"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Manage your privacy settings"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_biometric"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:paddingStart="2dp">

                    <LinearLayout
                        android:id="@+id/setting_contactus_container"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_quantity_selector"
                            android:gravity="center"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/call_outline"
                                app:tint="@color/md_theme_onSurfaceVariant"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contact Us"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Get in touch with our support team"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/arrow"
                            app:tint="@color/md_theme_outlineVariant"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_theme_outlineVariant"
                        android:layout_marginStart="56dp"/>

                    <LinearLayout
                        android:id="@+id/setting_help_container"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_quantity_selector"
                            android:gravity="center"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/help"
                                app:tint="@color/md_theme_onSurfaceVariant"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Help and Support"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Find answers and get assistance"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/arrow"
                            app:tint="@color/md_theme_outlineVariant"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_theme_outlineVariant"
                        android:layout_marginStart="56dp"/>

                    <LinearLayout
                        android:id="@+id/setting_terms_container"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_quantity_selector"
                            android:gravity="center"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/notes"
                                app:tint="@color/md_theme_onSurfaceVariant"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Terms &amp; Conditions "
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Read our terms and policies"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/arrow"
                            app:tint="@color/md_theme_outlineVariant"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_theme_outlineVariant"
                        android:layout_marginStart="56dp"/>

                    <LinearLayout
                        android:id="@+id/setting_logout_container"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_quantity_selector"
                            android:gravity="center"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/leave"
                                app:tint="@color/md_theme_onSurfaceVariant"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Logout"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Sign out from your account"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/arrow"
                            app:tint="@color/md_theme_outlineVariant"/>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>