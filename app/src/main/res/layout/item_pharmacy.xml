<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/md_theme_outlineVariant"
    app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/pharmacy_list_pharmacyName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Pharmacy Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:maxLines="1"
            android:ellipsize="end"
            android:letterSpacing="0.01"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/pharmacy_list_distance"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/pharmacy_list_distance"/>

        <TextView
            android:id="@+id/pharmacy_list_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.2 km"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimaryContainer"
            android:background="@drawable/bg_distance_chip"
            android:backgroundTint="@color/md_theme_primaryContainer"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/md_theme_outlineVariant"
            android:alpha="0.5"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/pharmacy_list_pharmacyName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/iconAddress"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/map_pin"
            android:layout_marginTop="12dp"
            app:tint="@color/md_theme_onSurfaceVariant"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"/>

        <TextView
            android:id="@+id/pharmacy_list_pharmacy_address"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="123 Main Street, Matara"
            android:textSize="13sp"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:layout_marginTop="12dp"
            android:layout_marginStart="7dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toEndOf="@id/iconAddress"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/iconPhone"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/call"
            android:layout_marginTop="8dp"
            app:tint="@color/md_theme_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pharmacy_list_pharmacy_address"/>

        <TextView
            android:id="@+id/pharmacy_list_contactNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="041 222 3333"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_primary"
            android:layout_marginStart="7dp"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toEndOf="@id/iconPhone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pharmacy_list_pharmacy_address"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>