<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item>

        <shape android:shape="rectangle">

            <solid android:color="#A6FFFFFF"/>

            <stroke
                android:width="1dp"
                android:color="#E0E0E0"/>

            <corners android:radius="25dp"/>

            <padding
                android:left="4dp"
                android:right="4dp"
                android:top="4dp"
                android:bottom="4dp"/>

        </shape>

    </item>

</selector>